   "source": [
    "# Gas Price - Temperature Correlation Analysis\n",
    "## Ciudad Juárez, Chihuahua, México\n",
    "\n",
    "### Project Overview\n",
    "This analysis investigates the relationship between natural gas prices and temperature variations in Ciudad Juárez, a border city with extreme climate conditions. The study aims to quantify how temperature changes affect energy costs through heating demand fluctuations.\n",
    "\n",
    "### Key Objectives\n",
    "1. Generate synthetic but realistic gas price and temperature datasets\n",
    "2. Analyze temporal patterns and correlations between variables\n",
    "3. Build predictive models for gas prices based on temperature\n",
    "4. Assess economic implications of climate variations\n",
    "\n",
    "### Methodology\n",
    "- Time series decomposition and stationarity testing\n",
    "- Cross-correlation analysis with lag effects\n",
    "- Regression modeling and hypothesis testing\n",
    "- Granger causality tests for predictive relationships"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Import Libraries and Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from datetime import datetime, timedelta\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Statistical libraries\n",
    "from scipy import stats\n",
    "import statsmodels.api as sm\n",
    "from statsmodels.tsa.stattools import grangercausalitytests, adfuller\n",
    "from statsmodels.tsa.seasonal import seasonal_decompose\n",
    "from statsmodels.graphics.tsaplots import plot_acf, plot_pacf\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.metrics import mean_squared_error, r2_score\n",
    "\n",
    "# Visualization settings\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette(\"husl\")\n",
    "%matplotlib inline\n",
    "\n",
    "# Set random seed for reproducibility\n",
    "np.random.seed(42)\n",
    "\n",
    "print(\"Libraries imported successfully!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Generate Synthetic Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_gas_temperature_data(start_date='2019-01-01', end_date='2024-12-31'):\n",
    "    \"\"\"Generate synthetic gas price and temperature data for Ciudad Juárez\"\"\"\n",
    "    \n",
    "    # Create date range\n",
    "    dates = pd.date_range(start=start_date, end=end_date, freq='D')\n",
    "    n_days = len(dates)\n",
    "    \n",
    "    # Ciudad Juárez climate characteristics (semi-arid, extreme temperatures)\n",
    "    # Summer highs: 35-40°C, Winter lows: -5 to 5°C\n",
    "    \n",
    "    # Base temperature with annual seasonality\n",
    "    day_of_year = dates.dayofyear\n",
    "    # Annual cycle: sine wave with peak in summer (July), trough in winter (January)\n",
    "    seasonal_temp = 15 + 20 * np.sin(2 * np.pi * (day_of_year - 105) / 365)  # Peak around mid-April adjusted\n",
    "    \n",
    "    # Climate change trend: +0.5°C over 5 years\n",
    "    trend_temp = np.linspace(0, 2.5, n_days)  # 0.5°C per year\n",
    "    \n",
    "    # Random variations (weather noise)\n",
    "    noise_temp = np.random.normal(0, 5, n_days)  # ±5°C daily variation\n",
    "    \n",
    "    # Combine components\n",
    "    temperature = seasonal_temp + trend_temp + noise_temp\n",
    "    \n",
    "    # Generate gas prices\n",
    "    # Base price with inflation trend\n",
    "    base_price = np.linspace(3.0, 5.0, n_days)  # From $3 to $5 per MMBtu over 5 years\n",
    "    \n",
    "    # Seasonal effect: higher prices in winter (heating demand)\n",
    "    # Inverse relationship with temperature (colder = higher price)\n",
    "    winter_peak = 1.5 * np.sin(2 * np.pi * (day_of_year - 365/2) / 365)  # Peak in winter\n",
    "    \n",
    "    # Price spikes during cold snaps\n",
    "    cold_snaps = np.zeros(n_days)\n",
    "    # Simulate random cold events\n",
    "    cold_days = np.random.choice(n_days, size=30, replace=False)\n",
    "    cold_snaps[cold_days] = np.random.uniform(0.5, 1.5, size=30)\n",
    "    \n",
    "    # Market volatility\n",
    "    volatility = np.random.normal(0, 0.2, n_days)\n",
    "    \n",
    "    # Combine price components\n",
    "    gas_price = base_price + winter_peak + cold_snaps + volatility\n",
    "    \n",
    "    # Ensure positive prices\n",
    "    gas_price = np.maximum(gas_price, 2.0)\n",
    "    \n",
    "    # Create DataFrame\n",
    "    df = pd.DataFrame({\n",
    "        'date': dates,\n",
    "        'temperature_c': np.round(temperature, 1),\n",
    "        'gas_price_usd': np.round(gas_price, 2),\n",
    "        'day_of_year': day_of_year,\n",
    "        'month': dates.month,\n",
    "        'year': dates.year,\n",
    "        'day_of_week': dates.dayofweek,\n",
    "        'is_winter': dates.month.isin([12, 1, 2]).astype(int),  # Dec, Jan, Feb\n",
    "        'is_summer': dates.month.isin([6, 7, 8]).astype(int)    # Jun, Jul, Aug\n",
    "    })\n",
    "    \n",
    "    # Calculate derived features\n",
    "    # Heating Degree Days (base 18°C)\n",
    "    df['hdd'] = np.maximum(18 - df['temperature_c'], 0)\n",
    "    # Cooling Degree Days (base 18°C)\n",
    "    df['cdd'] = np.maximum(df['temperature_c'] - 18, 0)\n",
    "    \n",
    "    # Price changes\n",
    "    df['price_change'] = df['gas_price_usd'].diff()\n",
    "    df['price_pct_change'] = df['gas_price_usd'].pct_change() * 100\n",
    "    \n",
    "    # Temperature anomalies (deviation from monthly average)\n",
    "    monthly_avg = df.groupby('month')['temperature_c'].transform('mean')\n",
    "    df['temp_anomaly'] = df['temperature_c'] - monthly_avg\n",
    "    \n",
    "    # Moving averages\n",
    "    df['temp_7d_avg'] = df['temperature_c'].rolling(window=7).mean()\n",
    "    df['price_7d_avg'] = df['gas_price_usd'].rolling(window=7).mean()\n",
    "    df['hdd_7d_sum'] = df['hdd'].rolling(window=7).sum()\n",
    "    \n",
    "    return df\n",
    "\n",
    "# Generate data\n",
    "data_df = generate_gas_temperature_data()\n",
    "print(f\"Dataset created with {len(data_df)} daily records from {data_df['date'].min().date()} to {data_df['date'].max().date()}\")\n",
    "print(f\"Variables: {', '.join(data_df.columns)}\")\n",
    "\n",
    "# Display sample\n",
    "display(data_df.head())\n",
    "print(\"\\nSummary statistics:\")\n",
    "display(data_df[['temperature_c', 'gas_price_usd', 'hdd', 'cdd']].describe())"
   ]
  },
