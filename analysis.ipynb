   "source": [
    "# Analyze impact of climate change (warming trend) on gas prices\n",
    "print(\"CLIMATE IMPACT ASSESSMENT\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Calculate warming trend\n",
    "temp_trend = temp_decomposition.trend.dropna()\n",
    "gas_trend = gas_decomposition.trend.dropna()\n",
    "\n",
    "# Align time indices\n",
    "common_idx = temp_trend.index.intersection(gas_trend.index)\n",
    "temp_trend_aligned = temp_trend.loc[common_idx]\n",
    "gas_trend_aligned = gas_trend.loc[common_idx]\n",
    "\n",
    "# Calculate temperature increase over period\n",
    "temp_start = temp_trend_aligned.iloc[0]\n",
    "temp_end = temp_trend_aligned.iloc[-1]\n",
    "temp_increase = temp_end - temp_start\n",
    "\n",
    "# Calculate corresponding gas price change\n",
    "gas_start = gas_trend_aligned.iloc[0]\n",
    "gas_end = gas_trend_aligned.iloc[-1]\n",
    "gas_change = gas_end - gas_start\n",
    "\n",
    "# Regression between trend components\n",
    "X_trend = sm.add_constant(temp_trend_aligned)\n",
    "y_trend = gas_trend_aligned\n",
    "trend_model = sm.OLS(y_trend, X_trend).fit()\n",
    "\n",
    "# Calculate expected price change due to warming\n",
    "expected_price_change = trend_model.params['x1'] * temp_increase\n",
    "\n",
    "print(f\"\\nTemperature Trend Analysis:\")\n",
    "print(f\"  Start temperature (trend): {temp_start:.2f}°C\")\n",
    "print(f\"  End temperature (trend): {temp_end:.2f}°C\")\n",
    "print(f\"  Temperature increase: {temp_increase:.2f}°C over {len(common_idx)/52:.1f} years\")\n",
    "print(f\"  Warming rate: {temp_increase / (len(common_idx)/52):.3f}°C per year\")\n",
    "\n",
    "print(f\"\\nGas Price Trend Analysis:\")\n",
    "print(f\"  Start price (trend): ${gas_start:.2f}/MMBtu\")\n",
    "print(f\"  End price (trend): ${gas_end:.2f}/MMBtu\")\n",
    "print(f\"  Actual price change: ${gas_change:.2f} ({gas_change/gas_start*100:.1f}%)\")\n",
    "\n",
    "print(f\"\\nClimate Impact Estimation:\")\n",
    "print(f\"  Regression: Price = {trend_model.params['const']:.3f} + {trend_model.params['x1']:.4f} * Temperature\")\n",
    "print(f\"  R-squared: {trend_model.rsquared:.4f}\")\n",
    "print(f\"  Expected price change due to {temp_increase:.2f}°C warming: ${expected_price_change:.3f}/MMBtu\")\n",
    "print(f\"  This represents {expected_price_change/gas_start*100:.2f}% of starting price\")\n",
    "\n",
    "# Winter vs Summer analysis\n",
    "winter_data = data_df[data_df['is_winter'] == 1]\n",
    "summer_data = data_df[data_df['is_summer'] == 1]\n",
    "\n",
    "print(f\"\\nSeasonal Analysis:\")\n",
    "print(f\"  Winter (Dec-Feb) correlation: {stats.pearsonr(winter_data['temperature_c'], winter_data['gas_price_usd'])[0]:.4f}\")\n",
    "print(f\"  Summer (Jun-Aug) correlation: {stats.pearsonr(summer_data['temperature_c'], summer_data['gas_price_usd'])[0]:.4f}\")\n",
    "print(f\"  Winter HDD vs Price correlation: {stats.pearsonr(winter_data['hdd'], winter_data['gas_price_usd'])[0]:.4f}\")\n",
    "\n",
    "# Economic impact calculation\n",
    "avg_daily_consumption_mmbtu = 100000  # Hypothetical daily consumption for Ciudad Juárez\n",
    "annual_consumption = avg_daily_consumption_mmbtu * 365\n",
    "\n",
    "additional_cost = expected_price_change * annual_consumption\n",
    "\n",
    "print(f\"\\nEconomic Impact Estimation (Hypothetical):\")\n",
    "print(f\"  Assumed daily consumption: {avg_daily_consumption_mmbtu:,} MMBtu\")\n",
    "print(f\"  Annual consumption: {annual_consumption:,} MMBtu\")\n",
    "print(f\"  Additional annual cost due to warming: ${additional_cost:,.0f}\")\n",
    "print(f\"  Monthly impact per household (100,000 households): ${additional_cost / 100000 / 12:,.2f}\")"
