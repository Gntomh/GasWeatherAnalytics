    "## 4. Statistical Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\" * 70)\n",
    "print(\"STATISTICAL ANALYSIS - GAS PRICE AND TEMPERATURE RELATIONSHIP\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "# 1. Pearson correlation\n",
    "corr_pearson, p_pearson = stats.pearsonr(data_df['temperature_c'].dropna(), \n",
    "                                        data_df['gas_price_usd'].dropna())\n",
    "print(f\"\\n1. PEARSON CORRELATION\")\n",
    "print(f\"   Correlation coefficient: {corr_pearson:.4f}\")\n",
    "print(f\"   P-value: {p_pearson:.6f}\")\n",
    "print(f\"   Interpretation: {'Significant' if p_pearson < 0.05 else 'Not significant'} at 95% confidence level\")\n",
    "print(f\"   Relationship: {'Negative' if corr_pearson < 0 else 'Positive'} correlation\")\n",
    "\n",
    "# 2. Spearman rank correlation (non-parametric)\n",
    "corr_spearman, p_spearman = stats.spearmanr(data_df['temperature_c'].dropna(), \n",
    "                                           data_df['gas_price_usd'].dropna())\n",
    "print(f\"\\n2. SPEARMAN RANK CORRELATION\")\n",
    "print(f\"   Correlation coefficient: {corr_spearman:.4f}\")\n",
    "print(f\"   P-value: {p_spearman:.6f}\")\n",
    "\n",
    "# 3. Cross-correlation analysis (lag effects)\n",
    "print(f\"\\n3. CROSS-CORRELATION ANALYSIS\")\n",
    "print(f\"   Investigating lag effects (temperature leading gas price changes)\")\n",
    "\n",
    "# Calculate cross-correlation for lags up to 30 days\n",
    "max_lag = 30\n",
    "cross_corr = []\n",
    "lags = range(-max_lag, max_lag + 1)\n",
    "\n",
    "for lag in lags:\n",
    "    if lag < 0:\n",
    "        # Temperature leads (gas price lags)\n",
    "        temp_series = data_df['temperature_c'].iloc[:lag].reset_index(drop=True)\n",
    "        price_series = data_df['gas_price_usd'].iloc[-lag:].reset_index(drop=True)\n",
    "    elif lag > 0:\n",
    "        # Gas price leads (temperature lags)\n",
    "        temp_series = data_df['temperature_c'].iloc[lag:].reset_index(drop=True)\n",
    "        price_series = data_df['gas_price_usd'].iloc[:-lag].reset_index(drop=True)\n",
    "    else:\n",
    "        # No lag\n",
    "        temp_series = data_df['temperature_c']\n",
    "        price_series = data_df['gas_price_usd']\n",
    "    \n",
    "    if len(temp_series) > 0 and len(price_series) > 0:\n",
    "        corr = np.corrcoef(temp_series, price_series)[0, 1]\n",
    "        cross_corr.append(corr)\n",
    "\n",
    "# Find optimal lag\n",
    "optimal_lag_idx = np.argmin(cross_corr)  # Most negative correlation\n",
    "optimal_lag = lags[optimal_lag_idx]\n",
    "optimal_corr = cross_corr[optimal_lag_idx]\n",
    "\n",
    "print(f\"   Optimal lag: {optimal_lag} days (temperature leads gas price by {-optimal_lag if optimal_lag < 0 else optimal_lag} days)\")\n",
    "print(f\"   Correlation at optimal lag: {optimal_corr:.4f}\")\n",
    "\n",
    "# 4. Regression analysis\n",
    "print(f\"\\n4. LINEAR REGRESSION ANALYSIS\")\n",
    "\n",
    "# Simple linear regression\n",
    "X_simple = sm.add_constant(data_df['temperature_c'].dropna())\n",
    "y_simple = data_df['gas_price_usd'].dropna()\n",
    "model_simple = sm.OLS(y_simple, X_simple).fit()\n",
    "\n",
    "print(f\"   Simple regression: Gas Price = {model_simple.params['const']:.3f} + {model_simple.params['temperature_c']:.4f} * Temperature\")\n",
    "print(f\"   R-squared: {model_simple.rsquared:.4f}\")\n",
    "print(f\"   P-value (temperature): {model_simple.pvalues['temperature_c']:.6f}\")\n",
    "\n",
    "# Multiple regression with HDD and seasonal dummies\n",
    "X_multi = pd.DataFrame({\n",
    "    'const': 1,\n",
    "    'temperature': data_df['temperature_c'],\n",
    "    'hdd': data_df['hdd'],\n",
    "    'month_2': (data_df['month'] == 2).astype(int),  # February dummy\n",
    "    'month_12': (data_df['month'] == 12).astype(int)  # December dummy\n",
    "})\n",
    "y_multi = data_df['gas_price_usd']\n",
    "\n",
    "# Drop rows with NaN\n",
    "valid_idx = X_multi.dropna().index.intersection(y_multi.dropna().index)\n",
    "X_multi_clean = X_multi.loc[valid_idx]\n",
    "y_multi_clean = y_multi.loc[valid_idx]\n",
    "\n",
    "model_multi = sm.OLS(y_multi_clean, X_multi_clean).fit()\n",
    "\n",
    "print(f\"\\n   Multiple regression results:\")\n",
    "for param in model_multi.params.index:\n",
    "    if param != 'const':\n",
    "        print(f\"   {param}: coeff = {model_multi.params[param]:.4f}, p = {model_multi.pvalues[param]:.6f}\")\n",
    "print(f\"   R-squared: {model_multi.rsquared:.4f}\")\n",
    "\n",
    "# 5. Stationarity tests (Augmented Dickey-Fuller)\n",
    "print(f\"\\n5. STATIONARITY TESTS (Augmented Dickey-Fuller)\")\n",
    "\n",
    "for series_name in ['temperature_c', 'gas_price_usd']:\n",
    "    series = data_df[series_name].dropna()\n",
    "    adf_result = adfuller(series)\n",
    "    \n",
    "    print(f\"   {series_name}:\")\n",
    "    print(f\"     ADF Statistic: {adf_result[0]:.4f}\")\n",
    "    print(f\"     P-value: {adf_result[1]:.6f}\")\n",
    "    print(f\"     Stationary: {'Yes' if adf_result[1] < 0.05 else 'No'}\")\n",
    "\n",
    "# 6. Granger causality test\n",
    "print(f\"\\n6. GRANGER CAUSALITY TESTS\")\n",
    "print(f\"   Testing if temperature Granger-causes gas price changes\")\n",
    "\n",
    "# Prepare data for Granger test\n",
    "test_data = data_df[['temperature_c', 'gas_price_usd']].dropna()\n",
    "\n",
    "# Test for different lag lengths\n",
    "maxlag = 7\n",
    "try:\n",
    "    granger_test = grangercausalitytests(test_data, maxlag=maxlag, verbose=False)\n",
    "    \n",
    "    print(f\"   Results for lags 1 to {maxlag}:\")\n",
    "    for lag in range(1, maxlag + 1):\n",
    "        p_value = granger_test[lag][0]['ssr_chi2test'][1]\n",
    "        print(f\"     Lag {lag}: p-value = {p_value:.6f} ({'Causal' if p_value < 0.05 else 'Not causal'})\")\n",
    "except Exception as e:\n",
    "    print(f\"   Granger test error: {e}\")\n",
    "\n",
    "print(\"\\n\" + \"=\" * 70)"
